{
  "name": "meditation-student-portal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm --recursive --if-present run build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "dev:api": "pnpm --filter @meditation/api dev",
    "dev:worker": "pnpm --filter @meditation/worker dev",
    "dev:admin": "pnpm --filter @meditation/admin dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pretypecheck": "pnpm --filter @meditation/core build && pnpm --filter @meditation/testing build",
    "typecheck": "pnpm --recursive --if-present run typecheck",
    "test": "pnpm --recursive --if-present run test",
    "db:generate": "pnpm --filter @meditation/database prisma:generate",
    "db:migrate": "pnpm --filter @meditation/database prisma:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^3.2.4"
  }
}
