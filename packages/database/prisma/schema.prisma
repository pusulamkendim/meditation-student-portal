generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StudentStatus {
  LEAD
  PAYMENT_PENDING
  ACTIVE
  INACTIVE
  PAUSED
  DELETION_PENDING
  DELETED
}

enum RegistrationStep {
  STARTED
  PRIVACY_NOTICE
  CHANNEL_OPT_IN
  AI_PREFERENCE
  NAME
  PAYMENT_INSTRUCTIONS
  PAYMENT_REVIEW
  COMPLETE
}

enum CurriculumStage {
  WEEK_1
  WEEK_2
  WEEK_3
  WEEK_4
  INTERMEDIATE
  ADVANCED
}

enum StageSource {
  AUTO
  ADMIN
}

enum ChannelType {
  WHATSAPP
  TELEGRAM
}

enum ChannelIdentityStatus {
  PENDING
  VERIFIED
  ACTIVE
  BLOCKED
  REVOKED
}

enum ConsentScope {
  MESSAGING
  AGENT_REPLY_AI
  REFLECTION_STORAGE
  REFLECTION_AI
}

enum ConsentStatus {
  GRANTED
  WITHDRAWN
}

enum PaymentStatus {
  REPORTED
  UNDER_REVIEW
  ACTION_REQUIRED
  APPROVED
  REJECTED
  REFUNDED
}

enum SubscriptionStatus {
  SCHEDULED
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PracticePlanStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  PAUSED
}

enum PracticeSessionStatus {
  SCHEDULED
  REMINDED
  AWAITING_RESPONSE
  COMPLETED
  SKIPPED
  MISSED
  CANCELLED
  SUPPRESSED
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum CalendarSyncStatus {
  PENDING
  SYNCED
  DISCREPANCY
  RECONNECT_REQUIRED
  FAILED
}

enum ConferenceStatus {
  PENDING
  READY
  FAILED
  MANUAL_OVERRIDE
}

enum MeetingScheduleAction {
  CREATED
  RESCHEDULED
  STATUS_CHANGED
}

enum SummarySource {
  DETERMINISTIC
  AI_DRAFT
}

enum GoogleCalendarConnectionStatus {
  DISCONNECTED
  CONNECTED
  RECONNECT_REQUIRED
}

enum CalendarDiscrepancyStatus {
  OPEN
  RESOLVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  RECEIVED
  ACCEPTED
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageIntentStatus {
  PENDING
  CLAIMED
  SENT
  DELIVERY_UNKNOWN
  DELIVERED
  READ
  FAILED
  SUPPRESSED
}

enum AdminRole {
  ADMIN
  ASSISTANT
  FINANCE
}

enum AuditActorType {
  ADMIN
  STUDENT
  SYSTEM
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  TELEGRAM
  ADMIN_PANEL
}

enum MessageAudience {
  STUDENT
  ADMIN
}

enum StandardMessageVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProviderTemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAUSED
}

enum ResponseOwner {
  SYSTEM_STANDARD_MESSAGE
  AGENT_CONTEXTUAL
  ADMIN_HANDOFF
  NO_REPLY
}

enum LlmProviderStatus {
  ENABLED
  DISABLED
}

enum LlmModelStatus {
  ACTIVE
  INACTIVE
}

enum LlmTask {
  INBOUND_INTENT
  AGENT_REPLY
  REFLECTION_TAGGING
  WEEKLY_SUMMARY
  KNOWLEDGE_EMBEDDING
  RAG_QUERY_REWRITE
  RAG_RERANK
}

enum LlmBudgetReservationStatus {
  RESERVED
  SETTLED
  RELEASED
  EXPIRED
}

enum KnowledgeStage {
  GENERAL
  WEEK_1
  WEEK_2
  WEEK_3
  WEEK_4
  INTERMEDIATE
  ADVANCED
}

enum KnowledgeDocumentVersionStatus {
  UPLOADED
  QUARANTINED
  SCANNING
  PARSING
  CHUNKING
  EMBEDDING
  READY
  PUBLISHED
  ARCHIVED
  FAILED
}

enum KnowledgeEmbeddingStatus {
  PENDING
  READY
  FAILED
}

enum HandoffStatus {
  OPEN
  RESOLVED
}

enum WeeklySummaryDraftStatus {
  DRAFT
  APPROVED
  SENT
  REJECTED
}

model SystemSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Student {
  id                       String          @id @default(uuid()) @db.Uuid
  status                   StudentStatus   @default(LEAD)
  registrationStep         RegistrationStep @default(STARTED) @map("registration_step")
  fullNameEncrypted        Bytes?          @map("full_name_encrypted")
  fullNameKeyId            String?         @map("full_name_key_id")
  phoneEncrypted           Bytes?          @map("phone_encrypted")
  phoneKeyId               String?         @map("phone_key_id")
  phoneHmac                String?         @unique @map("phone_hmac")
  timezone                 String          @default("Europe/Istanbul")
  preferredLocale          String          @default("tr-TR") @map("preferred_locale")
  curriculumStage          CurriculumStage @default(WEEK_1) @map("curriculum_stage")
  curriculumStageSource    StageSource     @default(AUTO) @map("curriculum_stage_source")
  defaultChannelIdentityId String?         @unique @map("default_channel_identity_id") @db.Uuid
  version                  Int             @default(1)
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")

  defaultChannelIdentity StudentChannelIdentity?  @relation("DefaultChannel", fields: [defaultChannelIdentityId], references: [id], onDelete: SetNull)
  channelIdentities      StudentChannelIdentity[] @relation("StudentIdentities")
  statusHistory          StudentStatusHistory[]
  privacyReceipts        PrivacyNoticeReceipt[]
  consents               Consent[]
  messagingPreference    MessagingPreference?
  payments               Payment[]
  subscriptions          SubscriptionPeriod[]
  practicePlans          PracticePlan[]
  practiceSessions       PracticeSession[]
  meetingSeries          MeetingSeries[]
  messages               Message[]
  messageIntents         MessageIntent[]
  inboxEvents            InboxEvent[]
  channelLinkTokens      ChannelLinkToken[]
  llmUsageLogs           LlmUsageLog[]
  agentContextReads      AgentContextRead[]
  knowledgeQueryLogs     RagQueryLog[]
  handoffs               Handoff[]
  notes                  StudentNote[]
  inboundIntentDecisions InboundIntentDecision[]

  @@index([status])
  @@map("students")
}

model StudentStatusHistory {
  id        String         @id @default(uuid()) @db.Uuid
  studentId String         @map("student_id") @db.Uuid
  from      StudentStatus?
  to        StudentStatus
  reason    String
  createdAt DateTime       @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@map("student_status_history")
}

model PrivacyNoticeReceipt {
  id                String      @id @default(uuid()) @db.Uuid
  studentId         String      @map("student_id") @db.Uuid
  noticeVersion     String      @map("notice_version")
  channel           ChannelType
  deliveredAt       DateTime    @map("delivered_at")
  externalMessageId String?     @map("external_message_id")
  createdAt         DateTime    @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, noticeVersion, channel])
  @@map("privacy_notice_receipts")
}

model Consent {
  id                String        @id @default(uuid()) @db.Uuid
  studentId         String        @map("student_id") @db.Uuid
  scope             ConsentScope
  status            ConsentStatus
  textVersion       String        @map("text_version")
  channel           ChannelType
  externalMessageId String?       @map("external_message_id")
  occurredAt        DateTime      @map("occurred_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, scope, occurredAt])
  @@map("consents")
}

model MessagingPreference {
  id               String    @id @default(uuid()) @db.Uuid
  studentId        String    @unique @map("student_id") @db.Uuid
  proactiveEnabled Boolean   @default(true) @map("proactive_enabled")
  pausedAt         DateTime? @map("paused_at")
  pauseReason      String?   @map("pause_reason")
  version          Int       @default(1)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("messaging_preferences")
}

model ChannelAccount {
  id          String      @id @default(uuid()) @db.Uuid
  type        ChannelType
  externalId  String      @map("external_id")
  displayName String      @map("display_name")
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  identities StudentChannelIdentity[]

  @@unique([type, externalId])
  @@map("channel_accounts")
}

model StudentChannelIdentity {
  id                    String                @id @default(uuid()) @db.Uuid
  studentId             String                @map("student_id") @db.Uuid
  channelAccountId      String                @map("channel_account_id") @db.Uuid
  externalUserEncrypted Bytes                 @map("external_user_encrypted")
  externalUserKeyId     String                @map("external_user_key_id")
  externalUserHmac      String                @map("external_user_hmac")
  status                ChannelIdentityStatus @default(PENDING)
  verifiedAt            DateTime?             @map("verified_at")
  lastInboundAt         DateTime?             @map("last_inbound_at")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  student           Student         @relation("StudentIdentities", fields: [studentId], references: [id], onDelete: Cascade)
  channelAccount    ChannelAccount  @relation(fields: [channelAccountId], references: [id], onDelete: Restrict)
  defaultForStudent Student?        @relation("DefaultChannel")
  messages          Message[]
  messageIntents    MessageIntent[]

  @@unique([channelAccountId, externalUserHmac])
  @@index([studentId, status])
  @@map("student_channel_identities")
}

model ChannelLinkToken {
  id          String      @id @default(uuid()) @db.Uuid
  studentId   String      @map("student_id") @db.Uuid
  channel     ChannelType
  tokenHash   String      @unique @map("token_hash")
  expiresAt   DateTime    @map("expires_at")
  usedAt      DateTime?   @map("used_at")
  revokedAt   DateTime?   @map("revoked_at")
  createdAt   DateTime    @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@index([studentId, expiresAt])
  @@map("channel_link_tokens")
}

model MessageDeliveryEvent {
  id                String        @id @default(uuid()) @db.Uuid
  channel           ChannelType
  externalMessageId String        @map("external_message_id")
  status            MessageStatus
  providerTimestamp DateTime      @map("provider_timestamp")
  payloadHash       String        @map("payload_hash")
  createdAt         DateTime      @default(now()) @map("created_at")
  @@unique([channel, externalMessageId, status, providerTimestamp, payloadHash])
  @@index([externalMessageId, providerTimestamp])
  @@map("message_delivery_events")
}

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  studentId             String        @map("student_id") @db.Uuid
  status                PaymentStatus @default(REPORTED)
  amountMinor           BigInt        @map("amount_minor")
  currency              String        @default("TRY")
  referenceCode         String        @unique @map("reference_code")
  proofStorageKey       String?       @map("proof_storage_key")
  proofDeleteAfter      DateTime?     @map("proof_delete_after")
  reviewNote            String?       @map("review_note")
  reportedAt            DateTime      @map("reported_at")
  approvedAt            DateTime?     @map("approved_at")
  approvedByAdminUserId String?       @map("approved_by_admin_user_id") @db.Uuid
  version               Int           @default(1)
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  student      Student             @relation(fields: [studentId], references: [id], onDelete: Restrict)
  subscription SubscriptionPeriod?
  approvedBy   AdminUser?          @relation(fields: [approvedByAdminUserId], references: [id], onDelete: Restrict)

  @@index([studentId, status])
  @@map("payments")
}

model SubscriptionPeriod {
  id           String             @id @default(uuid()) @db.Uuid
  studentId    String             @map("student_id") @db.Uuid
  paymentId    String?            @unique @map("payment_id") @db.Uuid
  status       SubscriptionStatus @default(SCHEDULED)
  startDate    DateTime           @map("start_date") @db.Date
  endExclusive DateTime           @map("end_exclusive") @db.Date
  priceMinor   BigInt             @default(400000) @map("price_minor")
  currency     String             @default("TRY")
  version      Int                @default(1)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  student       Student              @relation(fields: [studentId], references: [id], onDelete: Restrict)
  payment       Payment?             @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  creditEvents  MeetingCreditEvent[]
  practicePlans PracticePlan[]
  meetingSeries MeetingSeries[]

  @@index([studentId, status])
  @@map("subscription_periods")
}

model MeetingCreditEvent {
  id                   String   @id @default(uuid()) @db.Uuid
  subscriptionPeriodId String   @map("subscription_period_id") @db.Uuid
  delta                Int
  reason               String
  meetingId            String?  @map("meeting_id") @db.Uuid
  idempotencyKey       String   @unique @map("idempotency_key")
  createdAt            DateTime @default(now()) @map("created_at")

  subscriptionPeriod SubscriptionPeriod @relation(fields: [subscriptionPeriodId], references: [id], onDelete: Restrict)
  meeting            WeeklyMeeting?     @relation(fields: [meetingId], references: [id], onDelete: Restrict)

  @@index([subscriptionPeriodId, createdAt])
  @@index([meetingId, createdAt])
  @@map("meeting_credit_events")
}

model PracticePlan {
  id                   String             @id @default(uuid()) @db.Uuid
  studentId            String             @map("student_id") @db.Uuid
  subscriptionPeriodId String             @map("subscription_period_id") @db.Uuid
  status               PracticePlanStatus @default(DRAFT)
  revision             Int
  effectiveFrom        DateTime           @map("effective_from")
  effectiveUntil       DateTime?          @map("effective_until")
  version              Int                @default(1)
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  student            Student            @relation(fields: [studentId], references: [id], onDelete: Restrict)
  subscriptionPeriod SubscriptionPeriod @relation(fields: [subscriptionPeriodId], references: [id], onDelete: Restrict)
  slots              PracticeSlot[]
  sessions           PracticeSession[]

  @@unique([studentId, revision])
  @@index([studentId, status])
  @@map("practice_plans")
}

model PracticeSlot {
  id              String   @id @default(uuid()) @db.Uuid
  practicePlanId  String   @map("practice_plan_id") @db.Uuid
  slotKey         String   @map("slot_key")
  localTime       String   @map("local_time")
  durationMinutes Int      @map("duration_minutes")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  practicePlan PracticePlan      @relation(fields: [practicePlanId], references: [id], onDelete: Cascade)
  sessions     PracticeSession[]

  @@unique([practicePlanId, slotKey])
  @@map("practice_slots")
}

model PracticeSession {
  id              String                @id @default(uuid()) @db.Uuid
  studentId       String                @map("student_id") @db.Uuid
  practicePlanId  String                @map("practice_plan_id") @db.Uuid
  practiceSlotId  String?               @map("practice_slot_id") @db.Uuid
  serviceDate     DateTime              @map("service_date") @db.Date
  startAt         DateTime              @map("start_at")
  durationMinutes Int                   @map("duration_minutes")
  status          PracticeSessionStatus @default(SCHEDULED)
  replyNonceHmac  String?               @map("reply_nonce_hmac")
  cancelledAt     DateTime?             @map("cancelled_at")
  cancellationReason String?            @map("cancellation_reason")
  version         Int                   @default(1)
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  student      Student       @relation(fields: [studentId], references: [id], onDelete: Restrict)
  practicePlan PracticePlan  @relation(fields: [practicePlanId], references: [id], onDelete: Restrict)
  practiceSlot PracticeSlot? @relation(fields: [practiceSlotId], references: [id], onDelete: SetNull)
  reflection   PracticeReflection?

  @@unique([practicePlanId, serviceDate, practiceSlotId])
  @@index([studentId, startAt])
  @@index([status, startAt])
  @@map("practice_sessions")
}

model PracticeReflection {
  id                String   @id @default(uuid()) @db.Uuid
  practiceSessionId String   @unique @map("practice_session_id") @db.Uuid
  contentEncrypted  Bytes    @map("content_encrypted")
  contentKeyId      String   @map("content_key_id")
  createdAt         DateTime @default(now()) @map("created_at")

  practiceSession PracticeSession @relation(fields: [practiceSessionId], references: [id], onDelete: Cascade)
  tags            ReflectionTag[]

  @@map("practice_reflections")
}

model MeetingSeries {
  id                   String             @id @default(uuid()) @db.Uuid
  studentId            String             @map("student_id") @db.Uuid
  subscriptionPeriodId String             @map("subscription_period_id") @db.Uuid
  timezone             String
  recurrenceRule       String             @map("recurrence_rule")
  googleSeriesId       String?            @map("google_series_id")
  googleCalendarId     String?            @map("google_calendar_id")
  googleEtag           String?            @map("google_etag")
  calendarSyncStatus   CalendarSyncStatus @default(PENDING) @map("calendar_sync_status")
  conferenceStatus     ConferenceStatus   @default(PENDING) @map("conference_status")
  meetUrlEncrypted     Bytes?             @map("meet_url_encrypted")
  meetUrlKeyId         String?            @map("meet_url_key_id")
  lastCalendarSyncAt   DateTime?          @map("last_calendar_sync_at")
  version              Int                @default(1)
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  student            Student            @relation(fields: [studentId], references: [id], onDelete: Restrict)
  subscriptionPeriod SubscriptionPeriod @relation(fields: [subscriptionPeriodId], references: [id], onDelete: Restrict)
  meetings           WeeklyMeeting[]
  scheduleEvents     MeetingScheduleEvent[]
  discrepancies      CalendarDiscrepancy[]

  @@unique([subscriptionPeriodId])
  @@map("meeting_series")
}

model WeeklyMeeting {
  id                 String             @id @default(uuid()) @db.Uuid
  meetingSeriesId    String             @map("meeting_series_id") @db.Uuid
  occurrenceNumber   Int                @map("occurrence_number")
  startsAt           DateTime           @map("starts_at")
  endsAt             DateTime           @map("ends_at")
  originalStartsAt   DateTime?          @map("original_starts_at")
  status             MeetingStatus      @default(SCHEDULED)
  googleInstanceId   String?            @map("google_instance_id")
  googleEtag         String?            @map("google_etag")
  calendarSyncStatus CalendarSyncStatus @default(PENDING) @map("calendar_sync_status")
  lastCalendarSyncAt DateTime?          @map("last_calendar_sync_at")
  meetUrlEncrypted   Bytes?             @map("meet_url_encrypted")
  meetUrlKeyId       String?            @map("meet_url_key_id")
  version            Int                @default(1)
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  meetingSeries MeetingSeries          @relation(fields: [meetingSeriesId], references: [id], onDelete: Restrict)
  creditEvents  MeetingCreditEvent[]
  scheduleEvents MeetingScheduleEvent[]
  summary       WeeklySummary?
  draftVersions WeeklySummaryDraftVersion[]
  coachNotes    CoachNoteVersion[]
  discrepancies CalendarDiscrepancy[]

  @@unique([meetingSeriesId, occurrenceNumber])
  @@index([startsAt, status])
  @@map("weekly_meetings")
}

model MeetingScheduleEvent {
  id               String               @id @default(uuid()) @db.Uuid
  meetingSeriesId  String               @map("meeting_series_id") @db.Uuid
  meetingId        String?              @map("meeting_id") @db.Uuid
  action           MeetingScheduleAction
  previousStartsAt DateTime?            @map("previous_starts_at")
  newStartsAt      DateTime?            @map("new_starts_at")
  previousStatus   MeetingStatus?       @map("previous_status")
  newStatus        MeetingStatus?       @map("new_status")
  reason           String?
  adminUserId      String               @map("admin_user_id") @db.Uuid
  idempotencyKey   String               @unique @map("idempotency_key")
  createdAt        DateTime             @default(now()) @map("created_at")

  meetingSeries MeetingSeries  @relation(fields: [meetingSeriesId], references: [id], onDelete: Restrict)
  meeting       WeeklyMeeting? @relation(fields: [meetingId], references: [id], onDelete: Restrict)
  adminUser     AdminUser      @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([meetingSeriesId, createdAt])
  @@index([meetingId, createdAt])
  @@map("meeting_schedule_events")
}

model WeeklySummary {
  id                     String        @id @default(uuid()) @db.Uuid
  meetingId              String        @unique @map("meeting_id") @db.Uuid
  plannedPracticeCount   Int           @default(0) @map("planned_practice_count")
  completedPracticeCount Int           @default(0) @map("completed_practice_count")
  skippedPracticeCount   Int           @default(0) @map("skipped_practice_count")
  missedPracticeCount    Int           @default(0) @map("missed_practice_count")
  completionRate         Float         @default(0) @map("completion_rate")
  highlights             Json
  source                 SummarySource @default(DETERMINISTIC)
  generatedAt            DateTime      @map("generated_at")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  meeting WeeklyMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("weekly_summaries")
}

model CoachNoteVersion {
  id               String   @id @default(uuid()) @db.Uuid
  meetingId        String   @map("meeting_id") @db.Uuid
  version          Int
  content          String
  createdByAdminId String   @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  meeting        WeeklyMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdByAdmin AdminUser     @relation(fields: [createdByAdminId], references: [id], onDelete: Restrict)

  @@unique([meetingId, version])
  @@index([meetingId, createdAt])
  @@map("coach_note_versions")
}

model GoogleCalendarIntegration {
  id                    String                         @id @default("default")
  status                GoogleCalendarConnectionStatus @default(DISCONNECTED)
  refreshTokenEncrypted Bytes?                        @map("refresh_token_encrypted")
  refreshTokenKeyId     String?                        @map("refresh_token_key_id")
  calendarId            String?                        @map("calendar_id")
  calendarName          String?                        @map("calendar_name")
  lastSuccessfulSyncAt  DateTime?                      @map("last_successful_sync_at")
  version               Int                            @default(1)
  createdAt             DateTime                       @default(now()) @map("created_at")
  updatedAt             DateTime                       @updatedAt @map("updated_at")

  @@map("google_calendar_integrations")
}

model GoogleOAuthState {
  id                    String   @id @default(uuid()) @db.Uuid
  stateHash             String   @unique @map("state_hash")
  codeVerifierEncrypted Bytes    @map("code_verifier_encrypted")
  codeVerifierKeyId     String   @map("code_verifier_key_id")
  adminUserId           String   @map("admin_user_id") @db.Uuid
  expiresAt             DateTime @map("expires_at")
  usedAt                DateTime? @map("used_at")
  createdAt              DateTime @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([expiresAt, usedAt])
  @@map("google_oauth_states")
}

model GoogleCalendarSyncState {
  id                    String    @id @default("default")
  syncTokenEncrypted    Bytes?    @map("sync_token_encrypted")
  syncTokenKeyId        String?   @map("sync_token_key_id")
  lastIncrementalSyncAt DateTime? @map("last_incremental_sync_at")
  lastFullSyncAt        DateTime? @map("last_full_sync_at")
  nextFullReconcileAt   DateTime? @map("next_full_reconcile_at")
  version               Int       @default(1)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("google_calendar_sync_state")
}

model CalendarDiscrepancy {
  id               String                    @id @default(uuid()) @db.Uuid
  meetingSeriesId  String                    @map("meeting_series_id") @db.Uuid
  meetingId        String?                   @map("meeting_id") @db.Uuid
