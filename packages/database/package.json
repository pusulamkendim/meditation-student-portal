{
  "name": "@meditation/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://meditation:meditation@localhost:5433/meditation?schema=public} prisma migrate dev",
    "typecheck": "DATABASE_URL=${DATABASE_URL:-postgresql://meditation:meditation@localhost:5433/meditation?schema=public} prisma validate && tsc --noEmit",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@meditation/core": "workspace:*",
    "@prisma/client": "^6.19.0"
  },
  "devDependencies": {
    "prisma": "^6.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
