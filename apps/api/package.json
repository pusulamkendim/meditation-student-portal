{
  "name": "@meditation/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "pnpm --filter @meditation/core build && tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@meditation/core": "workspace:*",
    "@nestjs/common": "^11.1.11",
    "@nestjs/core": "^11.1.11",
    "@nestjs/platform-fastify": "^11.1.11",
    "fastify": "^5.6.2",
    "pino": "^9.9.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.11",
    "@types/node": "^22.15.3",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
