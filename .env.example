NODE_ENV=development
API_PORT=3000
ADMIN_ORIGIN=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000
DATABASE_URL=postgresql://meditation:meditation@localhost:5433/meditation?schema=public
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
DEFAULT_LOCALE=tr-TR
ALLOWED_RECIPIENTS=
QUEUE_SMOKE_JOB=false
# Required in staging/production. Values must come from deployment secrets.
DATA_ENCRYPTION_KEYS_JSON=
ACTIVE_DATA_KEY_ID=
LOOKUP_HMAC_KEY=
ADMIN_SESSION_HMAC_KEY=
AWS_SES_REGION=eu-central-1
ADMIN_EMAIL_FROM=
ADMIN_ALERT_EMAIL=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ACCOUNT_ID=default
WEBHOOK_BODY_LIMIT_BYTES=262144
PAYMENT_IBAN=
PAYMENT_ACCOUNT_HOLDER=
INTERNAL_COMMAND_SECRET=
# Google OAuth client secrets are deployment secrets; never commit or copy them from CHEATSHEET.md.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/v1/admin/google-calendar/oauth/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
GEMINI_API_KEY=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_QUARANTINE_BUCKET=meditation-quarantine
R2_PRIVATE_BUCKET=meditation-private
KNOWLEDGE_LOCAL_STORAGE_DIR=../../.data/knowledge
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
